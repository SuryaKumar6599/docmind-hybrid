# ============================================================
# DocMind Frontend — Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# NEVER commit .env.local — it contains your Supabase keys.
# ============================================================

# --- Supabase (required) ---
# Project URL: Supabase dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key: Supabase dashboard → Settings → API → anon / public
# Safe to use in the browser — RLS policies control access
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Local backend URL ---
# Start a Cloudflare Tunnel: cloudflared tunnel --url http://localhost:8000
# Paste the https://xxxx.trycloudflare.com URL here
VITE_DOCMIND_API_URL=https://xxxx.trycloudflare.com
