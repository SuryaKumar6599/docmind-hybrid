# ============================================================
# DocMind Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env — it contains secrets.
# ============================================================

# --- Supabase (required) ---
# Project URL: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key: Supabase dashboard → Settings → API → service_role (secret)
# ⚠️  Keep this secret — it bypasses RLS policies
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Ollama (local — defaults work if Ollama is running on localhost) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- CORS: comma-separated list of allowed frontend origins ---
# Add your Replit deployed URL or Vercel URL here
DOCMIND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://*.replit.dev,https://*.replit.app

# --- Token budget (8k total — matches Qwen2.5:7b context window) ---
TOKEN_BUDGET_TOTAL=8000

# --- Worker polling interval (seconds between Supabase polls) ---
WORKER_POLL_INTERVAL=10

# --- Optional: path to a branded .docx template for Stage 3 output ---
# DOCX_TEMPLATE_PATH=/path/to/your-template.docx

# --- llama.cpp provider (alternative to Ollama — set CHAT_PROVIDER=llamacpp to activate) ---
# Download GGUF files from HuggingFace before setting these paths.
# Apple Silicon install: CMAKE_ARGS="-DGGML_METAL=on" pip install "llama-cpp-python[server]>=0.3.0"
# NVIDIA CUDA install:   CMAKE_ARGS="-DGGML_CUDA=on"  pip install "llama-cpp-python[server]>=0.3.0"
#
# CHAT_PROVIDER=llamacpp
#
# Stage 1 chat model (Qwen2.5-7B-Instruct — equivalent to Ollama qwen2.5:7b)
# Download: https://huggingface.co/Qwen/Qwen2.5-7B-Instruct-GGUF
# LLAMACPP_CHAT_MODEL_PATH=/path/to/models/qwen2.5-7b-instruct-q4_k_m.gguf
# LLAMACPP_CHAT_MODEL_NAME=qwen2.5-7b-instruct
#
# Stage 2 premium chat model (Qwen2.5-32B-Instruct — equivalent to Ollama qwen3.6:27b)
# Download: https://huggingface.co/Qwen/Qwen2.5-32B-Instruct-GGUF
# LLAMACPP_PREMIUM_MODEL_PATH=/path/to/models/qwen2.5-32b-instruct-q4_k_m.gguf
# LLAMACPP_PREMIUM_MODEL_NAME=qwen2.5-32b-instruct
#
# Vision OCR model (Qwen2.5VL-7B — equivalent to Ollama qwen2.5vl:7b)
# Download: https://huggingface.co/Qwen/Qwen2.5-VL-7B-Instruct-GGUF
# Requires both the main model AND the mmproj (CLIP) file.
# LLAMACPP_VISION_MODEL_PATH=/path/to/models/qwen2.5vl-7b-instruct-q4_k_m.gguf
# LLAMACPP_VISION_MMPROJ_PATH=/path/to/models/qwen2.5vl-7b-mmproj.gguf
#
# Server tuning (defaults work well for Apple Silicon M-series)
# LLAMACPP_N_GPU_LAYERS=-1    # -1 = offload all layers to Metal/CUDA
# LLAMACPP_N_CTX=8192
# LLAMACPP_HOST=127.0.0.1
# LLAMACPP_PORT=8080
