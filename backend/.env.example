# ============================================================
# DocMind Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env — it contains secrets.
# ============================================================

# --- Supabase (required) ---
# Project URL: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key: Supabase dashboard → Settings → API → service_role (secret)
# ⚠️  Keep this secret — it bypasses RLS policies
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Ollama (local — defaults work if Ollama is running on localhost) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- CORS: comma-separated list of allowed frontend origins ---
# Add your Replit deployed URL or Vercel URL here
DOCMIND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://*.replit.dev,https://*.replit.app

# --- Token budget (8k total — matches Qwen2.5:7b context window) ---
TOKEN_BUDGET_TOTAL=8000

# --- Worker polling interval (seconds between Supabase polls) ---
WORKER_POLL_INTERVAL=10

# --- Optional: path to a branded .docx template for Stage 3 output ---
# DOCX_TEMPLATE_PATH=/path/to/your-template.docx
